    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.160.0",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
