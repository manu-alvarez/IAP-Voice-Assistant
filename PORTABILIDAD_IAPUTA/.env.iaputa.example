# ==========================================
# 🚀 IAPUTA OS FRONTEND - ENVIRONMENT TEMPLATE
# ==========================================
# Cópialo como '.env' en la raíz de tu proyecto IAPuta OS

# 1. API DE MOTOR DE VISIÓN (Llama-4-Scout)
# (Requerido para el "Vision Eye")
VITE_LLAMA_4_SCOUT_KEY=<tu-llama-scout-api-key>

# 2. MOTOR DE BÚSQUEDA WEB (Tavily/DDG)
VITE_TAVILY_API_KEY=<tu-tavily-api-key>

# 3. GOOGLE CALENDAR / HOTMAIL INTEGRATIONS
# Configuraciones de OAUTH - Descarga credenciales.json nativamente
VITE_GOOGLE_CLIENT_ID=<tu-google-client-id>
VITE_MICROSOFT_CLIENT_ID=<tu-microsoft-client-id>

# 4. DIRECCIÓN DEL BACKEND IAPUTA CORE
# (Si usas red Docker local= http://localhost:8080)
# (En el VPS = https://iaputa.alvarezconsult.com/api)
VITE_IAPUTA_CORE_URL=http://localhost:8080/api
