# ==========================================
# 🎙️ LIVEKIT / NIKOLINA - ENVIRONMENT TEMPLATE
# ==========================================
# Cópialo como '.env' en las carpetas /agent, /server y /dashboards

# 1. LIVEKIT CLOUD KEYS
# Obtén estas claves en: https://cloud.livekit.io/
LIVEKIT_URL=wss://<tu-instancia>.livekit.cloud
LIVEKIT_API_KEY=<tu-api-key>
LIVEKIT_API_SECRET=<tu-api-secret>

# 2. INTELIGENCIA ARTIFICIAL (GEMINI)
# Obtén esta clave en: https://aistudio.google.com/
GOOGLE_API_KEY=<tu-google-ai-studio-key>

# 3. OPENAI (OPCIONAL - Para Whisper o Plugins Lógicos)
# Obtén esta clave en: https://platform.openai.com/api-keys
OPENAI_API_KEY=<tu-openai-key>

# 4. CONFIGURACIÓN DEL SERVIDOR REST
# El Dashboard consumirá esta IP para leer las reservas
VITE_API_URL=http://localhost:8000/api
# Clave local para peticiones seguras
API_SECRET_KEY=IAPUTA_REST_SECRET_2026
